# Enterprise AI Platform — Environment Configuration
# Copy this to .env and fill in real values

# ── MongoDB ──────────────────────────────────────────────────────────────────
# For PRODUCTION (MongoDB Atlas):
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.rniaudm.mongodb.net/<dbname>?retryWrites=true&w=majority&appName=Cluster0
# For LOCAL development:
# MONGO_URI=mongodb://127.0.0.1:27017/
MONGO_DB=enterprise_ai

# ── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long, random string in production!
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel frontend URL here after deploying.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://my-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── SMTP Email ───────────────────────────────────────────────────────────────
# Leave blank to simulate — OTP and alerts will print to console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# For Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password   (use Google App Passwords, not your login password)
